# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommercedb
DB_USER=root
DB_PASSWORD=

# Worker behavior
BATCH_SIZE=5
SLEEP_MS=1500
DRY_RUN=false

# Source toggles
OPENALEX_ENABLED=true
CROSSREF_ENABLED=true

# Request timeout
REQUEST_TIMEOUT_MS=20000

# Scheduling
CRON_ENABLED=true
CRON_SCHEDULE=*/15 * * * 3,4
RUN_ON_START=true

# Logging
LOG_FILE=
