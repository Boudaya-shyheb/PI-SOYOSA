pipeline {
    agent any

    tools {
        nodejs 'NodeJS'
    }

    environment {
        APP_NAME = "ecommerce-insights-worker"
        DOCKER_IMAGE = "oussema22/pi-ecommerce-insights-worker"
        CD_JOB = "ecommerce-insights-worker-CD"
    }

    stages {

        stage('Checkout') {
            steps {
                cleanWs()
                retry(3) {
                    checkout scm
                }
            }
        }

        stage('Build & Test') {
            steps {
                dir('ecommerce-insights-worker') {
                    sh "npm ci"
                    sh "npm test -- --passWithNoTests"
                }
            }
        }

        stage('Lint') {
            steps {
                dir('ecommerce-insights-worker') {
                    sh "npm run lint -- --max-warnings=0 || true"
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('ecommerce-insights-worker') {
                    sh "docker build -t ${DOCKER_IMAGE} ."
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    sh """
                        echo $PASS | docker login -u $USER --password-stdin
                        docker push ${DOCKER_IMAGE}
                    """
                }
            }
        }

        stage('Trigger CD Pipeline') {
            steps {
                echo "🚀 Triggering CD pipeline..."
                build job: "${CD_JOB}", wait: false
            }
        }
    }

    post {
        success {
            echo "✅ CI finished successfully!"
        }

        failure {
            echo "❌ CI failed!"
        }

        always {
            cleanWs()
        }
    }
}
