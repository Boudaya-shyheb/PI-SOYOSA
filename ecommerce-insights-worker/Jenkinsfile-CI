pipeline {
    agent any

    tools {
        jdk   'JAVA_HOME'
        maven 'M2_HOME'
    }

    environment {
        SONARQUBE       = 'SonarQube'
        SERVICE_DIR     = 'ecommerce-insights-worker'
        DOCKER_IMAGE    = 'oussema22/pi-ecommerce-insights-worker'
        DOCKER_REGISTRY = 'docker.io'
    }

    triggers {
        githubPush()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Unit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'mvn clean verify -Dmaven.test.failure.ignore=false'
                }
            }
            post {
                always {
                    junit(
                        testResults: "**/target/surefire-reports/**/*.xml",
                        allowEmptyResults: true
                    )
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    withSonarQubeEnv("${SONARQUBE}") {
                        sh """
                            mvn sonar:sonar \\
                              -Dsonar.projectKey=PI-SOYOSA-${DOCKER_IMAGE.split('/')[1]} \\
                              -Dsonar.projectName="PI-SOYOSA ${SERVICE_DIR}" \\
                              -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Package') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'mvn package -DskipTests'
                }
            }
            post {
                success {
                    archiveArtifacts artifacts: '**/target/*.jar', fingerprint: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        def tag = "${env.BUILD_NUMBER}-${env.GIT_COMMIT.take(7)}"
                        docker.build("${DOCKER_REGISTRY}/${DOCKER_IMAGE}:${tag}")
                        docker.build("${DOCKER_REGISTRY}/${DOCKER_IMAGE}:latest")
                        env.DOCKER_TAG = tag
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', 'docker-hub-creds') {
                        docker.image("${DOCKER_REGISTRY}/${DOCKER_IMAGE}:${env.DOCKER_TAG}").push()
                        docker.image("${DOCKER_REGISTRY}/${DOCKER_IMAGE}:latest").push()
                    }
                }
            }
        }

    }

    post {
        success {
            build job: "PI-SOYOSA/${SERVICE_DIR}-CD",
                  parameters: [string(name: 'DOCKER_TAG', value: env.DOCKER_TAG)],
                  wait: false
        }
        failure {
            echo "${SERVICE_DIR} CI failed — CD will NOT be triggered."
        }
        always {
            cleanWs()
        }
    }
}
