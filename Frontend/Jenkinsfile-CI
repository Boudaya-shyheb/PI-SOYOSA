pipeline {
    agent any

    environment {
        SONARQUBE        = 'SonarQube'
        NODEJS_HOME      = tool 'NodeJS'   // Configure 'NodeJS' in Jenkins Global Tool
        PATH             = "${NODEJS_HOME}/bin:${env.PATH}"
        DOCKER_IMAGE     = 'oussema22/pi-frontend'
        DOCKER_REGISTRY  = 'docker.io'
    }

    triggers {
        githubPush()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('Frontend') {
                    sh 'npm ci'
                }
            }
        }

        stage('Lint') {
            steps {
                dir('Frontend') {
                    sh 'npm run lint -- --max-warnings=0'
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir('Frontend') {
                    sh 'npm run test -- --watchAll=false --coverage --coverageReporters=lcov'
                }
            }
            post {
                always {
                    junit(
                        testResults: 'Frontend/test-results/**/*.xml',
                        allowEmptyResults: true
                    )
                    publishHTML(target: [
                        allowMissing         : true,
                        alwaysLinkToLastBuild: true,
                        keepAll              : true,
                        reportDir            : 'Frontend/coverage/lcov-report',
                        reportFiles          : 'index.html',
                        reportName           : 'Frontend Coverage'
                    ])
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('Frontend') {
                    withSonarQubeEnv("${SONARQUBE}") {
                        sh '''
                            npx sonar-scanner \
                              -Dsonar.projectKey=PI-SOYOSA-Frontend \
                              -Dsonar.projectName="PI-SOYOSA Frontend" \
                              -Dsonar.sources=src \
                              -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                              -Dsonar.exclusions=**/node_modules/**,**/*.test.*,**/coverage/**
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build') {
            steps {
                dir('Frontend') {
                    sh 'npm run build'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('Frontend') {
                    script {
                        def tag = "${env.BUILD_NUMBER}-${env.GIT_COMMIT.take(7)}"
                        docker.build("${DOCKER_REGISTRY}/${DOCKER_IMAGE}:${tag}")
                        docker.build("${DOCKER_REGISTRY}/${DOCKER_IMAGE}:latest")
                        env.DOCKER_TAG = tag
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', 'docker-hub-creds') {
                        docker.image("${DOCKER_REGISTRY}/${DOCKER_IMAGE}:${env.DOCKER_TAG}").push()
                        docker.image("${DOCKER_REGISTRY}/${DOCKER_IMAGE}:latest").push()
                    }
                }
            }
        }

    }

    post {
        success {
            build job: 'PI-SOYOSA/Frontend-CD',
                  parameters: [string(name: 'DOCKER_TAG', value: env.DOCKER_TAG)],
                  wait: false
        }
        failure {
            echo "Frontend CI failed — CD pipeline will NOT be triggered."
        }
        always {
            cleanWs()
        }
    }
}
