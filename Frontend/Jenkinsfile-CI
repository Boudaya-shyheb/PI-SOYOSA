pipeline {
    agent any

    environment {
        NODEJS_HOME      = tool 'NodeJS'
        PATH             = "${NODEJS_HOME}/bin:${env.PATH}"
        DOCKER_IMAGE     = 'oussema22/pi-frontend'
        CD_JOB           = "frontend-CD"
    }

    stages {

        stage('Checkout') {
            steps {
                cleanWs()
                retry(3) {
                    checkout scm
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('Frontend') {
                    sh 'npm ci'
                }
            }
        }

        stage('Lint') {
            steps {
                dir('Frontend') {
                    sh 'npm run lint -- --max-warnings=0'
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir('Frontend') {
                    sh 'npm run test -- --watchAll=false --coverage --coverageReporters=lcov'
                }
            }

            post {
                always {
                    junit(
                        testResults: 'Frontend/test-results/**/*.xml',
                        allowEmptyResults: true
                    )
                    publishHTML(target: [
                        allowMissing         : true,
                        alwaysLinkToLastBuild: true,
                        keepAll              : true,
                        reportDir            : 'Frontend/coverage/lcov-report',
                        reportFiles          : 'index.html',
                        reportName           : 'Frontend Coverage'
                    ])
                }
            }
        }

        stage('Build') {
            steps {
                dir('Frontend') {
                    sh 'npm run build'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('Frontend') {
                    sh "docker build -t ${DOCKER_IMAGE} ."
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    sh """
                        echo $PASS | docker login -u $USER --password-stdin
                        docker push ${DOCKER_IMAGE}
                    """
                }
            }
        }

        stage('Trigger CD Pipeline') {
            steps {
                echo "🚀 Triggering CD pipeline..."
                build job: "${CD_JOB}", wait: false
            }
        }
            }
        }

    }

    post {
        success {
            build job: 'PI-SOYOSA/Frontend-CD',
                  parameters: [string(name: 'DOCKER_TAG', value: env.DOCKER_TAG)],
                  wait: false
        }
        failure {
            echo "Frontend CI failed — CD pipeline will NOT be triggered."
        }
        always {
            cleanWs()
        }
    }
}
