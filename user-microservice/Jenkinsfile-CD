pipeline {
    agent any

    parameters {
        string(name: 'DOCKER_TAG', defaultValue: 'latest', description: 'Docker image tag')
    }

    environment {
        SERVICE_NAME   = 'user-microservice'
        DOCKER_IMAGE   = 'oussema22/pi-user-microservice'
        NAMESPACE      = 'pi-soyosa'
        DEPLOYMENT     = 'user-microservice-deployment'
        KUBECONFIG     = "/var/lib/jenkins/.kube/config"
        TAG            = "${params.DOCKER_TAG ?: 'latest'}"
        DOCKER_IMAGE = "oussema22/pi-user-microservice"
        TAG = "${params.DOCKER_TAG ?: 'latest'}"
    }

    stages {

        stage('Check Kubernetes') {
            steps {
                sh '''
                    kubectl cluster-info
                    kubectl get nodes
                '''
            }
        }

        stage('Pull Docker Image') {
            steps {
                sh 'docker pull ${DOCKER_IMAGE}:${TAG}'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                dir('user-microservice') {

                    sh '''
                        kubectl apply -f user-microservice-deployment.yaml
                        kubectl apply -f user-microservice-service.yaml
                    '''

                    sh """
                        kubectl set image deployment/${DEPLOYMENT} \
                        user-microservice=${DOCKER_IMAGE}:${TAG} \
                        -n ${NAMESPACE}
                    """

                    sh '''
                        kubectl rollout status deployment/${DEPLOYMENT} \
                        -n ${NAMESPACE} --timeout=120s
                    '''
                }
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    kubectl get pods -n ${NAMESPACE}
                    kubectl get svc -n ${NAMESPACE}
                '''
            }
        }
    }

    post {

        success {
            echo 'CD pipeline completed successfully!'
        }

        failure {
            sh '''
                kubectl rollout undo deployment/${DEPLOYMENT} -n ${NAMESPACE} || true
            '''
            echo 'Deployment failed. Rollback executed.'
        }

        always {
            cleanWs()
        }
    }
}
