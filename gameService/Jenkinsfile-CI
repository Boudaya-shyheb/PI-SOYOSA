pipeline {
    agent any

    tools {
        jdk 'JAVA_HOME'
        maven 'M2_HOME'
    }

    environment {
        APP_NAME = "gameservice"
        DOCKER_IMAGE = "oussema22/pi-gameservice"
        CD_JOB = "gameservice-CD"
    }

    stages {

        stage('Checkout') {
            steps {
                cleanWs()
                retry(3) {
                    checkout scm
                }
            }
        }

        stage('Build & Test') {
            steps {
                dir('gameService') {
                    sh "mvn clean verify -Dmaven.test.failure.ignore=false"
                }
            }

            post {
                always {
                    junit 'gameService/target/surefire-reports/*.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('gameService') {
                    withSonarQubeEnv('SonarQube') {
                        sh """
                            mvn sonar:sonar \
                            -Dsonar.projectKey=PI-SOYOSA-gameservice \
                            -Dsonar.projectName=PI-SOYOSA-gameservice-microservice \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        """
                    }
                }
            }
        }

        stage('Package') {
            steps {
                dir('gameService') {
                    sh "mvn package -DskipTests"
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('gameService') {
                    sh "docker build -t ${DOCKER_IMAGE} ."
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    sh """
                        echo $PASS | docker login -u $USER --password-stdin
                        docker push ${DOCKER_IMAGE}
                    """
                }
            }
        }

        stage('Trigger CD Pipeline') {
            steps {
                echo "🚀 Triggering CD pipeline..."
                build job: "${CD_JOB}", wait: false
            }
        }
                              -Dsonar.projectName="PI-SOYOSA ${SERVICE_DIR}" \\
                              -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Package') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'mvn package -DskipTests'
                }
            }
            post {
                success {
                    archiveArtifacts artifacts: '**/target/*.jar', fingerprint: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        def tag = "${env.BUILD_NUMBER}-${env.GIT_COMMIT.take(7)}"
                        docker.build("${DOCKER_REGISTRY}/${DOCKER_IMAGE}:${tag}")
                        docker.build("${DOCKER_REGISTRY}/${DOCKER_IMAGE}:latest")
                        env.DOCKER_TAG = tag
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', 'docker-hub-creds') {
                        docker.image("${DOCKER_REGISTRY}/${DOCKER_IMAGE}:${env.DOCKER_TAG}").push()
                        docker.image("${DOCKER_REGISTRY}/${DOCKER_IMAGE}:latest").push()
                    }
                }
            }
        }

    }

    post {
        success {
            build job: "PI-SOYOSA/${SERVICE_DIR}-CD",
                  parameters: [string(name: 'DOCKER_TAG', value: env.DOCKER_TAG)],
                  wait: false
        }
        failure {
            echo "${SERVICE_DIR} CI failed — CD will NOT be triggered."
        }
        always {
            cleanWs()
        }
    }
}
