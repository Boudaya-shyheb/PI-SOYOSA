pipeline {
    agent any

    tools {
        jdk 'JAVA_HOME'
        maven 'M2_HOME'
    }

    environment {
        APP_NAME = "ecommerce-service"
        DOCKER_IMAGE = "oussema22/pi-ecommerce-microservice:latest"
        CD_JOB = "ecommerce-CD"   // 👈 Jenkins CD job name
    }

    stages {

        stage('Checkout') {
            steps {
                cleanWs()
                retry(3) {
                    checkout scm
                }
            }
        }

        stage('Build & Test') {
            steps {
                dir('ecommerce-microservice') {
                    sh "mvn clean verify -Dmaven.test.failure.ignore=false"
                }
            }

            post {
                always {
                    junit 'ecommerce-microservice/target/surefire-reports/*.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('ecommerce-microservice') {
                    withSonarQubeEnv('SonarQube') {
                        sh """
                            mvn sonar:sonar \
                            -Dsonar.projectKey=PI-SOYOSA-ecommerce \
                            -Dsonar.projectName=PI-SOYOSA-ecommerce-microservice \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        """
                    }
                }
            }
        }

        stage('Package') {
            steps {
                dir('ecommerce-microservice') {
                    sh "mvn package -DskipTests"
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('ecommerce-microservice') {
                    sh "docker build -t ${DOCKER_IMAGE} ."
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    sh """
                        echo $PASS | docker login -u $USER --password-stdin
                        docker push ${DOCKER_IMAGE}
                    """
                }
            }
        }

        stage('Trigger CD Pipeline') {
            steps {
                echo "🚀 Triggering CD pipeline..."
                build job: "${CD_JOB}", wait: false
            }
        }
    }

    post {
        success {
            echo "✅ CI finished successfully!"
        }

        failure {
            echo "❌ CI failed!"
        }

        always {
            cleanWs()
        }
    }
}
