pipeline {
    agent any

    tools {
        jdk   'JAVA_HOME'
        maven 'M2_HOME'
    }

    environment {
        SONARQUBE       = 'SonarQube'
        SERVICE_DIR     = 'courses-microservice'
        DOCKER_IMAGE    = 'oussema22/pi-courses-microservice'
        DOCKER_REGISTRY = 'docker.io'
    }

    triggers {
        githubPush()
    }

    stages {

        stage('Prepare Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout (Stable Git)') {
            steps {
                script {
                    retry(3) {
                        checkout([$class: 'GitSCM',
                            branches: scm.branches,
                            userRemoteConfigs: scm.userRemoteConfigs,
                            extensions: [
                                [$class: 'CloneOption', shallow: true, depth: 1, noTags: false, timeout: 20]
                            ]
                        ])
                    }
                }
            }
        }

        stage('Build & Unit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'mvn clean verify -Dmaven.test.failure.ignore=false'
                }
            }
            post {
                always {
                    junit testResults: "**/target/surefire-reports/**/*.xml",
                          allowEmptyResults: true
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    withSonarQubeEnv("${SONARQUBE}") {
                        sh """
                            mvn sonar:sonar \
                              -Dsonar.projectKey=PI-SOYOSA-${env.JOB_NAME} \
                              -Dsonar.projectName="PI-SOYOSA ${SERVICE_DIR}" \
                              -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        """
                    }
                }
            }
        }

        stage('Package') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'mvn package -DskipTests'
                }
            }
            post {
                success {
                    archiveArtifacts artifacts: '**/target/*.jar', fingerprint: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        def tag = "${env.BUILD_NUMBER}-${env.GIT_COMMIT.take(7)}"
                        def image = "${DOCKER_REGISTRY}/${DOCKER_IMAGE}"

                        docker.build("${image}:${tag}")
                        docker.build("${image}:latest")

                        env.DOCKER_TAG = tag
                        env.IMAGE_NAME = image
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', 'docker-hub-creds') {
                        docker.image("${env.IMAGE_NAME}:${env.DOCKER_TAG}").push()
                        docker.image("${env.IMAGE_NAME}:latest").push()
                    }
                }
            }
        }
    }

    post {
        success {
            build job: "PI-SOYOSA/${SERVICE_DIR}-CD",
                  parameters: [
                      string(name: 'DOCKER_TAG', value: env.DOCKER_TAG)
                  ],
                  wait: false
        }

        failure {
            echo "CI FAILED → CD NOT TRIGGERED"
        }

        always {
            cleanWs()
        }
    }
}
