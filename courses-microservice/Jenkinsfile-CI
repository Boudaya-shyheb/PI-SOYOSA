pipeline {
    agent any

    tools {
        jdk 'JAVA_HOME'
        maven 'M2_HOME'
    }

    environment {
        APP_NAME = "course-management"
        DOCKER_IMAGE = "your-dockerhub-username/course-management:latest"
    }

    stages {

        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
            }
        }

        stage('Build & Unit Tests') {
            steps {
                dir('courses-microservice') {
                    sh "mvn clean verify -Dmaven.test.failure.ignore=false"
                }
            }

            post {
                always {
                    junit 'courses-microservice/target/surefire-reports/*.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('courses-microservice') {
                    withSonarQubeEnv('SonarQube') {
                        sh """
                            mvn sonar:sonar \
                            -Dsonar.projectKey=PI-SOYOSA-courses \
                            -Dsonar.projectName=PI-SOYOSA-courses-microservice \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        """
                    }
                }
            }
        }

        stage('Package') {
            steps {
                dir('courses-microservice') {
                    sh "mvn package -DskipTests"
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('courses-microservice') {
                    sh """
                        docker build -t ${DOCKER_IMAGE} .
                    """
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-cred', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    sh """
                        echo $PASS | docker login -u $USER --password-stdin
                        docker push ${DOCKER_IMAGE}
                    """
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }

        success {
            echo "✅ Pipeline finished successfully!"
        }

        failure {
            echo "❌ Pipeline failed!"
        }
    }
}
