pipeline {
    agent any

    environment {
        SERVICE_NAME   = 'api-gateway'
        DOCKER_IMAGE   = 'oussema22/pi-api-gateway'
        NAMESPACE      = 'pi-soyosa'
        DEPLOYMENT     = 'api-gateway-deployment'
        KUBECONFIG = "/var/lib/jenkins/.kube/config"
    }

    stages {

        stage('Check Kubernetes') {
            steps {
                sh '''
                    kubectl cluster-info
                    kubectl get nodes
                '''
            }
        }

        stage('Pull Docker Image') {
            steps {
                sh '''
                    docker pull ${DOCKER_IMAGE}:latest
                '''
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                dir('api-gateway') {

                    sh '''
                        kubectl apply -f api-gateway-deployment.yaml
                        kubectl apply -f api-gateway-service.yaml
                    '''

                    sh '''
                        kubectl set image deployment/${DEPLOYMENT} \
                        api-gateway=${DOCKER_IMAGE}:latest \
                        -n ${NAMESPACE}
                    '''

                    sh '''
                        kubectl rollout status deployment/${DEPLOYMENT} \
                        -n ${NAMESPACE} --timeout=120s
                    '''
                }
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    kubectl get pods -n ${NAMESPACE}
                    kubectl get svc -n ${NAMESPACE}
                '''
            }
        }
    }

    post {

        success {
            echo 'CD pipeline completed successfully!'
        }

        failure {
            sh '''
                kubectl rollout undo deployment/${DEPLOYMENT} -n ${NAMESPACE} || true
            '''
            echo 'Deployment failed. Rollback executed.'
        }

        always {
            cleanWs()
        }
    }
}
